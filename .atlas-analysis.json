  "keyFeatures": [
    "No browser or Selenium required — connects via WebSocket directly",
    "QR code and pairing code authentication",
    "Send and receive all WhatsApp message types (text, media, polls, reactions)",
    "Group management (create, add/remove members, settings)",
    "Privacy controls (block/unblock, last seen, read receipts)",
    "Presence and chat state updates",
    "Broadcast lists and WhatsApp Stories support",
    "Full TypeScript types and IntelliSense support",
    "Signal Protocol encryption for secure messaging",
    "Pluggable auth state and data store"
  ],
  "publicApiSurface": [
    "makeWASocket(config: SocketConfig): WASocket",
    "useMultiFileAuthState(folder: string)",
    "makeCacheableSignalKeyStore(keys, logger)",
    "makeInMemoryStore({})",
    "fetchLatestBaileysVersion()",
    "downloadMediaMessage(msg, type, options)",
    "downloadContentFromMessage(msg, type)",
    "getContentType(message)",
    "getDevice(message)",
    "getAggregateVotesInPollMessage(options)",
    "generateMessageIDV2()",
    "sock.sendMessage(jid, content, options?)",
    "sock.readMessages(keys[])",
    "sock.sendPresenceUpdate(type, jid?)",
    "sock.chatModify(mod, jid)",
    "sock.groupCreate(subject, participants[])",
    "sock.groupParticipantsUpdate(jid, participants[], action)",
    "sock.groupMetadata(jid)",
    "sock.groupInviteCode(jid)",
    "sock.groupAcceptInvite(code)",
    "sock.groupToggleEphemeral(jid, seconds)",
    "sock.fetchPrivacySettings()",
    "sock.updateBlockStatus(jid, action)",
    "sock.onWhatsApp(jid[])",
    "sock.fetchStatus(jid)",
    "sock.profilePictureUrl(jid, type?)",
    "sock.presenceSubscribe(jid)",
    "sock.updateProfileName(name)",
    "sock.updateProfileStatus(status)",
    "sock.requestPairingCode(phoneNumber)",
    "sock.rejectCall(callId, callFrom)",
    "sock.ev.on(event, handler)",
    "sock.ev.off(event, handler)",
    "sock.ev.process(handler)",
    "BaileysEventMap (all events)",
    "SocketConfig (all socket options)",
    "AnyMessageContent (all message types)",
    "WAMessage, WAMessageKey, WAMediaUpload"
  ]
}
