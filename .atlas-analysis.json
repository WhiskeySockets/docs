  "projectType": "sdk-library",
  "projectName": "Baileys",
  "projectDescription": "A WebSocket-based TypeScript/JavaScript library for interacting with the WhatsApp Web API without requiring a browser.",
  "theme": "luma",
  "primaryColor": "#18cdb1",
  "lightColor": null,
  "darkColor": null,
